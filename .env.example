# Banco de dados (serviço postgres do docker-compose.yml, próprio deste app)
POSTGRES_PASSWORD=senha-segura-aqui
# Schema do Postgres usado por este app (use underscores, nunca hífen)
DATABASE_SCHEMA=kairos_base

# Segurança
SECRET_KEY=gere-uma-chave-aleatoria-segura

# Identidade do tenant (a empresa/cliente que usa esta instância do app)
TENANT_NOME=Empresa Exemplo
TENANT_SLUG=empresa-exemplo

# Master inicial (criado automaticamente no primeiro start)
ADMIN_EMAIL=admin@exemplo.com
ADMIN_PASSWORD=defina-uma-senha-forte-aqui

# Login com Google (OAuth2) — opcional, além do login por e-mail/senha
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.seuapp.exemplo.com/api/auth/google/callback

# SMTP (recuperação de senha) — se vazio, o link de redefinição é apenas
# logado no console do backend (útil em desenvolvimento)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@seuapp.exemplo.com

# URL pública do frontend, para onde o backend redireciona após o login Google
FRONTEND_URL=https://seuapp.exemplo.com

# Portas publicadas pelo docker-compose (ajuste por app/deploy para evitar
# colisão na mesma VPS)
BACKEND_PORT=8000
FRONTEND_PORT=3000
