NODE_ENV=production
PORT=3001

# Google OAuth - https://console.cloud.google.com
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
GOOGLE_REDIRECT_URI=https://seu-dominio.com/api/auth/google/callback

# JWT
JWT_SECRET=gere_uma_chave_forte_aqui_minimo_32_chars

# Frontend URL
FRONTEND_URL=https://seu-dominio.com

# Email (conta Gmail com senha de app)
EMAIL_FROM=kairos@obpcsorocaba.com.br
EMAIL_PASS=senha_de_app_gmail

# Admin inicial (e-mail da sede)
ADMIN_EMAIL=admin@obpcsorocaba.com.br

# OpenRouter API Key (para Assistente IA)
OPENROUTER_API_KEY=sk-or-v1-sua_chave_aqui

# Banco de dados SQLite
DB_PATH=/app/data/kairos.db
